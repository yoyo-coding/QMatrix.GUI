<Window
    x:Class="QMatrix.GUI.Views.AdapterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMatrix.GUI.Views"
    Title="QMatrix 适配向导"
    Width="600"
    Height="400"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ScrollViewer Grid.Row="0" Margin="20">
            <StackPanel>
                <TextBlock Text="QMatrix 适配向导" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                
                <TextBlock Text="检测到 QMatrix 核心程序已安装，是否执行自动适配？" FontSize="16" Margin="0,0,0,10"/>
                
                <TextBlock Text="适配内容：" FontSize="14" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBlock Text="1. 检查并创建 HTTP 服务" Margin="20,0,0,5"/>
                <TextBlock Text="2. 复制配置文件" Margin="20,0,0,5"/>
                <TextBlock Text="3. 启动 QMatrix Core 服务" Margin="20,0,0,5"/>
                <TextBlock Text="4. 启动 HTTP API 服务" Margin="20,0,0,5"/>
                <TextBlock Text="5. 更新 GUI 配置" Margin="20,0,0,5"/>
                
                <TextBlock Text="预期效果：" FontSize="14" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBlock Text="- QMatrix.GUI 将能够与 QMatrix 核心服务进行通信" Margin="20,0,0,5"/>
                <TextBlock Text="- 提供完整的聊天和工具调用功能" Margin="20,0,0,5"/>
                <TextBlock Text="- 保持用户现有配置和数据安全" Margin="20,0,0,5"/>
                
                <TextBlock Text="所需权限：" FontSize="14" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBlock Text="- 读取和写入配置文件" Margin="20,0,0,5"/>
                <TextBlock Text="- 启动和管理后台服务进程" Margin="20,0,0,5"/>
                
                <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0" Margin="0,20,0,10"/>
                <TextBlock x:Name="ProgressText" Text="准备就绪" HorizontalAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,20,20">
            <Button x:Name="CancelButton" Content="取消" Width="100" Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button x:Name="ConfirmButton" Content="确认" Width="100" Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
