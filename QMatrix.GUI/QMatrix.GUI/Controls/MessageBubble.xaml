<UserControl
    x:Class="QMatrix.GUI.Controls.MessageBubble"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">

    <Grid>
        <Border
            x:Name="MessageBorder"
            CornerRadius="8"
            Padding="12"
            Margin="0,4"
            HorizontalAlignment="{Binding HorizontalAlignment, ElementName=MessageBorder}">
            <StackPanel>
                <TextBlock
                    x:Name="MessageText"
                    TextWrapping="Wrap"
                    FontSize="14"
                    LineHeight="20"/>
                <TextBlock
                    x:Name="TimestampText"
                    FontSize="10"
                    Opacity="0.6"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
