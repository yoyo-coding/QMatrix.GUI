<Page
    x:Class="QMatrix.GUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:QMatrix.GUI.Controls"
    xmlns:viewmodels="using:QMatrix.GUI.ViewModels"
    xmlns:models="using:QMatrix.GUI.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <DataTemplate x:Key="MessageTemplate" x:DataType="models:QMMessage">
            <controls:MessageBubble Message="{x:Bind}" />
        </DataTemplate>

        <DataTemplate x:Key="HistoryItemTemplate" x:DataType="models:QMHistoryItem">
            <StackPanel Padding="8">
                <TextBlock 
                    Text="{x:Bind Title}" 
                    FontSize="14" 
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis"/>
                <TextBlock 
                    Text="{x:Bind UpdatedAt, Converter={StaticResource DateTimeFormatConverter}}" 
                    FontSize="11" 
                    Opacity="0.6"
                    Margin="0,2,0,0"/>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 历史列表侧边栏 -->
        <Border 
            Grid.Column="0" 
            BorderBrush="{ThemeResource CardStrokeColorDefault}" 
            BorderThickness="0,0,1,0"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" Padding="16,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock 
                            Text="QMatrix GUI" 
                            FontSize="20" 
                            FontWeight="SemiBold"/>
                        <TextBlock 
                            Text="历史记录" 
                            FontSize="12" 
                            Opacity="0.6"
                            Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 历史列表 -->
                <ListView 
                    Grid.Row="1"
                    ItemsSource="{x:Bind HistoryViewModel.HistoryItems, Mode=OneWay}"
                    ItemTemplate="{StaticResource HistoryItemTemplate}"
                    SelectedItem="{x:Bind HistoryViewModel.SelectedItem, Mode=TwoWay}"
                    SelectionMode="Single"
                    Margin="8,0"
                    VerticalAlignment="Stretch">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="CornerRadius" Value="6"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Padding" Value="8"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- 新建对话按钮 -->
                <Button 
                    Grid.Row="2"
                    Content="新建对话"
                    HorizontalAlignment="Stretch"
                    Margin="16"
                    Click="NewConversation_Click"/>
            </Grid>
        </Border>

        <!-- 对话区域 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 消息列表 -->
            <ScrollViewer 
                x:Name="MessagesScrollViewer"
                Grid.Row="0"
                Padding="24"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl 
                    ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                    ItemTemplate="{StaticResource MessageTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- 输入区域 -->
            <Border 
                Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefault}"
                BorderThickness="0,1,0,0"
                Padding="24,16"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox 
                        x:Name="InputTextBox"
                        Grid.Column="0"
                        PlaceholderText="在这里输入消息..."
                        Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MaxHeight="150"
                        VerticalAlignment="Center"
                        KeyDown="InputTextBox_KeyDown"/>

                    <Button 
                        Grid.Column="1"
                        Content="发送"
                        Command="{x:Bind ViewModel.SendMessageCommand}"
                        IsEnabled="{x:Bind ViewModel.IsSending, Converter={StaticResource BoolNegationConverter}, Mode=OneWay}"
                        MinWidth="100"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
